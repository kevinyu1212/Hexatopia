<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hexatopia - 메인 대시보관</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .section-title { font-size: 18px; font-weight: 700; color: var(--text-bold); margin: 35px 0 15px 0; display: flex; align-items: center; gap: 8px; }
        .live-indicator { width: 8px; height: 8px; background: #3fb950; border-radius: 50%; display: inline-block; animation: blink 1.5s infinite; }
        @keyframes blink { 0% { opacity: 0.4; } 50% { opacity: 1; } 100% { opacity: 0.4; } }
    </style>
</head>
<body>
    <div class="main-wrapper">
        <header>
            <div class="logo" onclick="location.href='/'">Hexatopia</div>
            
            <div class="header-right">
                <% if (session.isLoggedIn) { %>
                    <span style="font-size:13px; color:var(--text-muted); display:inline-block; max-width:90px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; vertical-align:middle;">👤 <%= session.nickname %></span>
                    <a href="/toggle-auth" class="btn-auth-combined" style="color: #f85149; border-color: rgba(248,81,73,0.3);">로그아웃</a>
                <% } else { %>
                    <a href="/toggle-auth" class="btn-auth-combined">로그인 / 회원가입</a>
                <% } %>

                <button class="hamburger-btn" id="menuToggle">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </header>

        <div class="sidebar-overlay" id="overlay"></div>
        <div class="mobile-sidebar" id="sidebar">
            <div style="padding-bottom: 12px; border-bottom: 1px solid var(--border-color); font-size: 13px; font-weight: bold; color: var(--text-muted); letter-spacing: 0.5px;">
                HEXATOPIA NAVIGATION
            </div>
            <a href="/">🏠 홈 대시보드</a>
            <a href="/feed">📱 오픈 피드</a>
            <a href="/map">🗺️ 생태 시민과학 지도</a>
            <a href="/forum">💬 대안 학술 포럼</a>
            <a href="/mypage">📊 관제 마이페이지</a>
            <a href="/market">🛒 AI 안심 분양 마켓</a>
        </div>

        <div class="container">
            <div class="card" style="text-align: center; padding: 45px 20px;">
                <h1 style="color:var(--text-bold); font-size: 2.2rem; margin:0 0 12px 0;">곤충 연구원들의 메타 네트워크</h1>
                <p style="color: var(--text-muted); font-size: 14px; max-width: 600px; margin: 0 auto 25px auto;">
                    체계적인 누대 혈통 데이터베이스 관리부터 집단지성 시민과학 생태지도까지, 헥사토피아에서 숨 쉬는 데이터를 만나보세요.
                </p>
                <div class="grid">
                    <div class="card" style="margin:0; padding:15px; background:rgba(255,255,255,0.01);"><span style="color:var(--text-muted); font-size:13px;">정회원 수</span><h2 style="margin:5px 0 0 0; color:#58a6ff;"><%= stats.users %> 명</h2></div>
                    <div class="card" style="margin:0; padding:15px; background:rgba(255,255,255,0.01);"><span style="color:var(--text-muted); font-size:13px;">아카이빙 개체</span><h2 style="margin:5px 0 0 0; color:#3fb950;"><%= stats.insectsCount %> 령</h2></div>
                    <div class="card" style="margin:0; padding:15px; background:rgba(255,255,255,0.01);"><span style="color:var(--text-muted); font-size:13px;">월간 거래 안전도</span><h2 style="margin:5px 0 0 0; color:#ff9800;">99.9 %</h2></div>
                </div>
            </div>

            <div class="section-title"><div class="live-indicator"></div> 🔥 지금 핫한 사육·채집 트렌드</div>
            <div class="grid">
                <% trendingFeeds.forEach(feed => { %>
                    <div class="card" style="margin:0; display:flex; flex-direction:column; justify-content:space-between; min-height:160px;">
                        <div>
                            <div style="display:flex; justify-content:space-between; font-size:12px; margin-bottom:8px;">
                                <span class="badge success">[<%= feed.type %>]</span>
                                <span style="color:var(--text-muted);"><%= feed.author %></span>
                            </div>
                            <h4 style="margin:5px 0; color:var(--text-bold); font-size:15px;"><%= feed.title %></h4>
                            <p style="font-size:13px; color:var(--text-muted); margin:5px 0;"><%= feed.content %></p>
                        </div>
                        <div style="font-size:12px; color:#58a6ff; margin-top:10px;">♥ 공감 <%= feed.likes %></div>
                    </div>
                <% }) %>
            </div>

            <div class="two-col-grid" style="margin-top: 15px;">
                <div>
                    <div class="section-title"><div class="live-indicator"></div> 🗺️ 실시간 전국 곤충 발견 피드</div>
                    <div class="card" style="margin:0; min-height: 250px;">
                        <% recentPins.forEach(pin => { %>
                            <div class="list-item">
                                <div><strong style="color:var(--text-bold); font-size:14px;">[<%= pin.species %>]</strong><span style="font-size:13px; color:var(--text-muted); margin-left:6px;"><%= pin.locName %></span></div>
                                <div style="font-size:12px; color:var(--text-muted);"><%= pin.finder %> • <%= pin.time %></div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <div>
                    <div class="section-title">🛍️ AI 인증 추천 분양 매물</div>
                    <div style="display:flex; flex-direction:column; gap:12px;">
                        <% premiumGoods.forEach(item => { %>
                            <div class="card" style="margin:0; background:rgba(46,160,67,0.02); border-color:rgba(46,160,67,0.25);">
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                                    <span class="badge success" style="background:rgba(56,139,253,0.12); color:#58a6ff;"><%= item.aiChecked %></span>
                                    <span style="font-size:12px; color:var(--text-muted);"><%= item.lineage %></span>
                                </div>
                                <h4 style="margin:4px 0; color:var(--text-bold);"><%= item.title %></h4>
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-top:12px;">
                                    <span style="color:#3fb950; font-weight:700; font-size:15px;"><%= item.price.toLocaleString() %> 원</span>
                                    <span style="font-size:12px; color:var(--text-muted);"><%= item.seller %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <footer>
        <div class="footer-links">
            <a href="/">이용약관</a>
            <a href="/">개인정보처리방침</a>
            <a href="/forum">가이드라인</a>
            <a href="/admin" style="color:#ff9800;">관제탑</a>
        </div>
        <div>© 2026 Hexatopia Insect Citizen Science Platform. All Rights Reserved.</div>
    </footer>

    <script>
        const menuToggle = document.getElementById('menuToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');

        function toggleMenu() {
            sidebar.classList.toggle('active');
            overlay.classList.toggle('active');
        }

        menuToggle.addEventListener('click', toggleMenu);
        overlay.addEventListener('click', toggleMenu);
    </script>
</body>
</html>
